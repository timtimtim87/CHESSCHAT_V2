@startuml
left to right direction
skinparam linetype ortho
skinparam defaultTextAlignment center

actor "Internet Users" as internet_users

rectangle "AWS us-east-1" {
  rectangle "VPC\nchesschat-dev-vpc-main\n10.20.0.0/16" as vpc
  rectangle "Internet Gateway\nigw-08c762aa9e0f534b1" as igw
  rectangle "NAT Gateway\nnat-0dee142da7453a5f9" as nat

  frame "Public Subnets" {
    rectangle "us-east-1a\n10.20.0.0/20" as pub_a
    rectangle "us-east-1b\n10.20.16.0/20" as pub_b
    rectangle "us-east-1c\n10.20.32.0/20" as pub_c
  }

  frame "Private App Subnets" {
    rectangle "us-east-1a\n10.20.48.0/20" as app_a
    rectangle "us-east-1b\n10.20.64.0/20" as app_b
    rectangle "us-east-1c\n10.20.80.0/20" as app_c
  }

  frame "Private Data Subnets" {
    rectangle "us-east-1a\n10.20.96.0/20" as data_a
    rectangle "us-east-1b\n10.20.112.0/20" as data_b
    rectangle "us-east-1c\n10.20.128.0/20" as data_c
  }

  frame "Route Tables" {
    rectangle "public\nrtb-0769e0346dce66198" as rt_public
    rectangle "app-1a\nrtb-05c2a8d8ef55f8e44" as rt_app_a
    rectangle "app-1b\nrtb-0344e2f09e6880252" as rt_app_b
    rectangle "app-1c\nrtb-0ee6b3f73ec07e73d" as rt_app_c
    rectangle "data-1a\nrtb-0ca39cb2160302101" as rt_data_a
    rectangle "data-1b\nrtb-091d2f66825ec5f4f" as rt_data_b
    rectangle "data-1c\nrtb-01ba84fa231b06cc2" as rt_data_c
  }

  frame "VPC Endpoints" {
    rectangle "S3\nvpce-083e6eb89fff2117b" as ep_s3
    rectangle "DynamoDB\nvpce-02779bd6e7a7e9be5" as ep_ddb
    rectangle "ECR API\nvpce-0f33be281603357f6" as ep_ecr_api
    rectangle "ECR DKR\nvpce-000b7ae5082191c41" as ep_ecr_dkr
    rectangle "CloudWatch Logs\nvpce-0c03bd6affeadc424" as ep_logs
    rectangle "Secrets Manager\nvpce-0541a547c67809804" as ep_sm
  }

  rectangle "VPC Flow Logs\nfl-05f30eba368dcc3fd" as flow_logs
  rectangle "CloudWatch Log Group\n/aws/vpc/chesschat-dev-vpc/flow-logs" as cw_logs
}

internet_users --> igw
igw --> pub_a

vpc --> pub_a
vpc --> pub_b
vpc --> pub_c
vpc --> app_a
vpc --> app_b
vpc --> app_c
vpc --> data_a
vpc --> data_b
vpc --> data_c

pub_a --> rt_public
pub_b --> rt_public
pub_c --> rt_public
rt_public --> igw : 0.0.0.0/0

pub_a --> nat

app_a --> rt_app_a
app_b --> rt_app_b
app_c --> rt_app_c
rt_app_a --> nat : 0.0.0.0/0
rt_app_b --> nat : 0.0.0.0/0
rt_app_c --> nat : 0.0.0.0/0

data_a --> rt_data_a
data_b --> rt_data_b
data_c --> rt_data_c
rt_data_a --> nat : 0.0.0.0/0
rt_data_b --> nat : 0.0.0.0/0
rt_data_c --> nat : 0.0.0.0/0

app_a --> ep_ecr_api
app_b --> ep_ecr_api
app_c --> ep_ecr_api
app_a --> ep_ecr_dkr
app_b --> ep_ecr_dkr
app_c --> ep_ecr_dkr
app_a --> ep_logs
app_b --> ep_logs
app_c --> ep_logs
app_a --> ep_sm
app_b --> ep_sm
app_c --> ep_sm

app_a --> ep_s3
app_b --> ep_s3
app_c --> ep_s3
data_a --> ep_s3
data_b --> ep_s3
data_c --> ep_s3

app_a --> ep_ddb
app_b --> ep_ddb
app_c --> ep_ddb
data_a --> ep_ddb
data_b --> ep_ddb
data_c --> ep_ddb

vpc --> flow_logs
flow_logs --> cw_logs
@enduml
